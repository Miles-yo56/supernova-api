/* style.css */

/* Corpo geral */
body {
    background-color: #1E1E2F;
    color: #fff;
    font-family: Arial, sans-serif;
    text-align: center;
    padding-top: 30px;
}

/* Cabeçalho */
header {
    background: #1E90FF;
    padding: 15px;
    text-align: center;
    font-size: 24px;
}

/* Navegação */
nav a {
    color: #00BFFF;
    margin: 0 10px;
    text-decoration: none;
    font-weight: bold;
}

/* Botões/links Dev */
.dev-only {
    display: inline-block;
    background: #FFD700;
    padding: 5px 10px;
    border-radius: 5px;
    cursor: pointer;
}

/* Inputs e formulários */
input[type="text"], input[type="file"], input[type="submit"] {
    padding: 10px;
    font-size: 16px;
    margin: 5px;
}

/* Links gerais */
a {
    color: #00BFFF;
    font-weight: bold;
    text-decoration: none;
}

/* Títulos h2 */
h2 {
    margin-top: 20px;
}
