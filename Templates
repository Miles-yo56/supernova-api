<!DOCTYPE html>
<html>
<head>
    <title>Login Supernova</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
    <img src="{{ url_for('static', filename='images/login.png') }}"/>
    <h2>Forneça seu token</h2>
    <form method="post">
        <input type="text" name="token" placeholder="Insira seu token"/><br><br>
        <input type="submit" value="Entrar"/>
    </form>
    {% if error %}
        <p class="error">{{ error }}</p>
    {% endif %}
    <p>Não encontrou o que precisava? <a href="mailto:gabrielsantosprodrigues85@gmail.com">Contate o Dev</a></p>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
    <title>Supernova Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
<header>Supernova Space - {{ role }}</header>
<nav>
    <a href="{{ url_for('home', token=token) }}">Home</a>
    <a href="{{ url_for('perfil', token=token) }}">Perfil</a>
    <a href="{{ url_for('frequencia', token=token) }}">Frequência</a>
    <a href="{{ url_for('pe_de_meia', token=token) }}">Pé de Meia</a>
    <a href="{{ url_for('olimpico', token=token) }}">Olimpíadas</a>
    <a href="{{ url_for('cultura', token=token) }}">Cultura</a>
    {% if role.startswith("Dev") %}
        <span class="dev-only"><a href="{{ url_for('dev', token=token) }}">Dev</a></span>
    {% endif %}
</nav>
<section>
    <h2>Bem-vindo, {{ role }}!</h2>
    <p>Escolha uma aba acima para navegar pelas funções do sistema.</p>
</section>
</body>
</html>
