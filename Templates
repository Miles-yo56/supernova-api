<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Dashboard - {{ perfil }}</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body { background-color: #f0f8ff; }
.nav-link.active { font-weight: bold; color: #0d6efd !important; }
.tab-content { padding: 20px; background-color: #fff; border-radius: 12px; margin-top: 10px; }
</style>
</head>
<body class="p-3">
<div class="container">
    <h2 class="mb-3">Bem-vindo, {{ perfil }}!</h2>
    <p>Data: {{ data }} | Hora: {{ hora }}</p>

    <ul class="nav nav-tabs" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pe-de-meia-tab" data-bs-toggle="tab" data-bs-target="#pe-de-meia" type="button">Pé de Meia</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="frequencia-tab" data-bs-toggle="tab" data-bs-target="#frequencia" type="button">Frequência</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="cultura-tab" data-bs-toggle="tab" data-bs-target="#cultura" type="button">Cultura</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="links-tab" data-bs-toggle="tab" data-bs-target="#links" type="button">Links úteis</button>
        </li>
        {% if perfil == "Dev" %}
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="liberar-tab" data-bs-toggle="tab" data-bs-target="#liberar" type="button">Liberar</button>
        </li>
        {% endif %}
    </ul>

    <div class="tab-content">
        <!-- Pé de Meia -->
        <div class="tab-pane fade show active" id="pe-de-meia">
            <h4>Pé de Meia</h4>
            <table class="table table-striped">
                <thead>
                    <tr><th>Mês</th><th>Valor</th><th>Data Pagamento</th></tr>
                </thead>
                <tbody>
                    {% for item in pe_de_meia %}
                    <tr><td>{{ item.mes }}</td><td>R$ {{ item.valor }}</td><td>{{ item.data_pagamento }}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Frequência -->
        <div class="tab-pane fade" id="frequencia">
            <h4>Frequência</h4>
            <canvas id="frequenciaChart" width="400" height="200"></canvas>
        </div>

        <!-- Cultura -->
        <div class="tab-pane fade" id="cultura">
            <h4>Cultura</h4>
            <ul>
                <li><a href="https://www.youtube.com/c/TecMundo" target="_blank">Canal Tec Mundo</a></li>
                <li><a href="https://www.youtube.com/c/CienciaTodoDia" target="_blank">Ciência Todo Dia</a></li>
                <li><a href="https://www.youtube.com/c/MatematicaNoPapel" target="_blank">Matemática no Papel</a></li>
                <li><a href="https://www.pinterest.com/" target="_blank">Pinterest</a></li>
            </ul>
        </div>

        <!-- Links úteis -->
        <div class="tab-pane fade" id="links">
            <h4>Links úteis</h4>
            <ul>
                {% for link in links %}
                <li><a href="{{ link.url }}" target="_blank">{{ link.nome }}</a></li>
                {% endfor %}
            </ul>
        </div>

        <!-- Liberar (apenas Dev) -->
        {% if perfil == "Dev" %}
        <div class="tab-pane fade" id="liberar">
            <h4>Liberar Usuário</h4>
            <form method="POST" action="/liberar">
                <div class="mb-3">
                    <label for="usuario" class="form-label">Nome do Usuário</label>
                    <input type="text" class="form-control" id="usuario" name="usuario">
                </div>
                <button type="submit" class="btn btn-success">Liberar</button>
            </form>
        </div>
        {% endif %}
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const ctx = document.getElementById('frequenciaChart').getContext('2d');
const frequenciaChart = new Chart(ctx, {
    type: 'bar',
    data: {
        labels: ['Português','Matemática','Ciências','Geografia','Artes','Ed. Física','Inglês'],
        datasets: [{
            label: 'Frequência (%)',
            data: [80, 90, 85, 70, 95, 100, 88],
            backgroundColor: 'rgba(13,110,253,0.7)'
        }]
    },
    options: {
        scales: { y: { beginAtZero: true, max: 100 } }
    }
});
</script>
</body>
</html>
